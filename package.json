{
  "name": "ketcher-desktop",
  "version": "3.18.0-rc.2",
  "description": "Ketcher chemical structure editor — desktop app",
  "homepage": "https://github.com/epam/ketcher",
  "author": {
    "name": "David",
    "email": "david@katalystnord.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:ketcher": "bash scripts/build-ketcher.sh",
    "build": "npm run build:ketcher && electron-builder",
    "dist": "npm run build:ketcher && electron-builder --publish never",
    "pack": "npm run build:ketcher && electron-builder --dir",
    "update-ketcher": "bash scripts/update-ketcher.sh",
    "sync-version": "node -e \"const v=require('./ketcher/packages/ketcher-react/package.json').version; require('child_process').execSync('npm pkg set version='+v,{stdio:'inherit'}); console.log('→ Version synced to '+v);\""
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "playwright-core": "^1.61.1"
  },
  "build": {
    "appId": "com.ketcher.desktop",
    "productName": "Ketcher Desktop",
    "copyright": "EPAM Systems (Ketcher) — Electron wrapper",
    "asar": true,
    "asarUnpack": [
      "**/*.wasm",
      "**/*.node"
    ],
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "ketcher/example/dist",
        "to": "ketcher-dist",
        "filter": [
          "**/*",
          "!remote/**",
          "!static/**",
          "!standalone/static/js/popup.*",
          "!standalone/static/js/duo.*",
          "!standalone/static/js/closable.*"
        ]
      }
    ],
    "electronLanguages": [
      "en-US"
    ],
    "afterPack": "./scripts/appimage-wrap.cjs",
    "directories": {
      "output": "dist-electron"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Science;Education",
      "desktop": {
        "entry": {
          "Keywords": "chemistry;molecule;structure;editor;SMILES;molfile;reaction;InChI;CML;ketcher;",
          "MimeType": "chemical/x-mdl-molfile;chemical/x-mdl-rxnfile;chemical/x-mdl-sdfile;chemical/x-smiles;chemical/x-cml;chemical/x-inchi;",
          "StartupNotify": "true"
        }
      },
      "extraFiles": [
        {
          "from": "build/com.ketcher.desktop.metainfo.xml",
          "to": "usr/share/metainfo/com.ketcher.desktop.metainfo.xml"
        }
      ]
    },
    "deb": {
      "afterInstall": "scripts/deb-after-install.sh",
      "afterRemove": "scripts/deb-after-remove.sh"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
