<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.ketcher.desktop</id>

  <name>Ketcher Desktop</name>
  <summary>Chemical structure editor for desktop</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>Apache-2.0</project_license>

  <developer_name>David — Katalyst Nord</developer_name>

  <description>
    <p>
      Ketcher Desktop is a native desktop application wrapping the Ketcher chemical
      structure editor by EPAM Systems. It runs fully offline using a WebAssembly-based
      chemistry engine — no backend server is required.
    </p>
    <p>Key features:</p>
    <ul>
      <li>Fast 2D structure drawing to common chemical standards</li>
      <li>3D structure visualization via Miew</li>
      <li>Template library including custom and user templates</li>
      <li>Stereochemistry support during editing, loading, and saving</li>
      <li>Undo/redo history</li>
      <li>Load and save in MDL Molfile, RXN, InChI, ChemAxon Extended SMILES, and CML formats</li>
      <li>Macromolecules editing mode</li>
      <li>OCR — recognize structures from image files</li>
      <li>Copy and paste between chemical editors</li>
      <li>Runs fully offline — no Indigo backend needed</li>
    </ul>
  </description>

  <launchable type="desktop-id">ketcher-desktop.desktop</launchable>

  <url type="homepage">https://github.com/epam/ketcher</url>
  <url type="bugtracker">https://github.com/YOUR_ORG/ketcher-desktop/issues</url>
  <url type="vcs-browser">https://github.com/YOUR_ORG/ketcher-desktop</url>

  <keywords>
    <keyword>chemistry</keyword>
    <keyword>chemical</keyword>
    <keyword>structure</keyword>
    <keyword>molecule</keyword>
    <keyword>editor</keyword>
    <keyword>SMILES</keyword>
    <keyword>molfile</keyword>
    <keyword>reaction</keyword>
    <keyword>ketcher</keyword>
  </keywords>

  <categories>
    <category>Science</category>
